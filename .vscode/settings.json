    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": ["comment"],
                "settings": {
                    "foreground": "#8da9c4"
                }
            },
            {
                "scope": ["string"],
                "settings": {
                    "foreground": "#eef4ed"
                }
            },
            {
                "scope": ["variable"],
                "settings": {
                    "foreground": "#eef4ed"
                }
            },
            {
                "scope": ["keyword"],
                "settings": {
                    "foreground": "#134074"
                }
            }
        ]
    }
